# 복사 후 .env 로 저장해 사용하세요.
# cp .env.example .env

# SQLite (로컬 단독)
DATABASE_URL=sqlite:///./blog.db
# Docker Compose Postgres 예시 (호스트에서 API 실행 시)
# DATABASE_URL=postgresql+psycopg2://blog:blog@localhost:5432/blog

SECRET_KEY=please-use-a-long-random-string-in-real-deployments
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
APP_NAME=Clean Blog API
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=5242880
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
